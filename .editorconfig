root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false
indent_size = 2

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.{ps1,psm1,psd1}]
indent_size = 4
end_of_line = crlf

[*.cmd]
end_of_line = crlf

[*.{js,mjs,cjs,ts,jsx,tsx}]
indent_size = 2

[*.py]
indent_size = 4

[Makefile]
indent_style = tab
